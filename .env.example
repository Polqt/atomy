# Supabase public keys (anon key only — never put service_role key here)
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon_key_from_supabase_settings_api>

# Backend API URL
# Development: set to your local machine IP (run `ipconfig`, use IPv4 under Wi-Fi adapter)
# Preview/Production: injected automatically via eas.json build profile — no change needed here
EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:3000
