# Node environment
NODE_ENV=development
PORT=3000

# PostgreSQL connection (Supabase → Settings → Database → URI mode, Transaction pooler)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<host>.pooler.supabase.com:6543/postgres?sslmode=require

# Supabase (Settings → API)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role_jwt_from_supabase>
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/keys

# Groq (console.groq.com → API Keys)
GROQ_API_KEY=gsk_<your_groq_api_key>
GROQ_MODEL=llama3-8b-8192

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000
