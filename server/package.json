{
  "name": "atomy-server",
  "version": "1.0.0",
  "description": "Atomy NestJS Backend - Habit AI Generation",
  "main": "dist/main.js",
  "scripts": {
    "start": "node dist/main.js",
    "dev": "nest start --watch",
    "build": "nest build",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed": "ts-node seed.ts",
    "setup:dirs": "node -e \"const fs = require('fs'); const path = require('path'); const dirs = ['src/common/guards', 'src/common/decorators', 'src/shared/ai']; dirs.forEach(d => fs.mkdirSync(path.join(__dirname, d), { recursive: true })); console.log('Directories created');\""
  },
  "keywords": [],
